generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String   @unique
  password  String
  avatar    String?
  banner    String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Отношения
  animeFavorites    Favorite[]
  animeWatchlist    Watchlist[]
  mangaFavorites    MangaFavorite[]
  mangaReadlist     MangaReadlist[]
  ranobeFavorites   RanobeFavorite[]
  ranobeReadlist    RanobeReadlist[]
}

model Anime {
  id            Int      @id @default(autoincrement())
  title         String
  originalTitle String?
  image         String
  episodes      Int
  status        String   // airing, finished, upcoming
  type          String   // TV, Movie, OVA, etc.
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Отношения
  favorites    Favorite[]
  watchlist    Watchlist[]
}

model Manga {
  id            Int      @id @default(autoincrement())
  title         String
  originalTitle String?
  image         String
  chapters      Int?
  status        String   // ongoing, completed, hiatus
  type          String   // manga, manhwa, manhua
  mangaDexId    String?  // ID в MangaDex API
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Отношения
  favorites    MangaFavorite[]
  readlist    MangaReadlist[]
}

model Ranobe {
  id            Int      @id @default(autoincrement())
  title         String
  originalTitle String?
  image         String
  volumes       Int?
  chapters      Int?
  status        String   // ongoing, completed, hiatus
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Отношения
  favorites    RanobeFavorite[]
  readlist    RanobeReadlist[]
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  animeId   Int
  createdAt DateTime @default(now())

  // Отношения
  user      User     @relation(fields: [userId], references: [id])
  anime     Anime    @relation(fields: [animeId], references: [id])

  @@unique([userId, animeId])
}

model Watchlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  animeId   Int
  status    String   // watching, completed, planned, dropped
  progress  Int      @default(0)
  score     Int?     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Отношения
  user      User     @relation(fields: [userId], references: [id])
  anime     Anime    @relation(fields: [animeId], references: [id])

  @@unique([userId, animeId])
}

model MangaFavorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  mangaId   Int
  createdAt DateTime @default(now())

  // Отношения
  user      User     @relation(fields: [userId], references: [id])
  manga     Manga    @relation(fields: [mangaId], references: [id])

  @@unique([userId, mangaId])
}

model MangaReadlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  mangaId   Int
  status    String   // reading, completed, planned, dropped
  progress  Int      @default(0)
  score     Int?     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Отношения
  user      User     @relation(fields: [userId], references: [id])
  manga     Manga    @relation(fields: [mangaId], references: [id])

  @@unique([userId, mangaId])
}

model RanobeFavorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  ranobeId  Int
  createdAt DateTime @default(now())

  // Отношения
  user      User     @relation(fields: [userId], references: [id])
  ranobe    Ranobe   @relation(fields: [ranobeId], references: [id])

  @@unique([userId, ranobeId])
}

model RanobeReadlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  ranobeId  Int
  status    String   // reading, completed, planned, dropped
  progress  Int      @default(0)
  score     Int?     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Отношения
  user      User     @relation(fields: [userId], references: [id])
  ranobe    Ranobe   @relation(fields: [ranobeId], references: [id])

  @@unique([userId, ranobeId])
} 