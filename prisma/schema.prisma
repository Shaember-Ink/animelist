generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String   @unique
  password  String
  avatar    String?
  banner    String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Отношения
  animeFavorites    Favorite[]
  animeWatchlist    Watchlist[]
}

model Anime {
  id            Int      @id @default(autoincrement())
  title         String
  originalTitle String?
  image         String
  episodes      Int
  status        String   // airing, finished, upcoming
  type          String   // TV, Movie, OVA, etc.
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Отношения
  favorites    Favorite[]
  watchlist    Watchlist[]
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  animeId   Int
  createdAt DateTime @default(now())

  // Отношения
  user      User     @relation(fields: [userId], references: [id])
  anime     Anime    @relation(fields: [animeId], references: [id])

  @@unique([userId, animeId])
}

model Watchlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  animeId   Int
  status    String   // watching, completed, planned, dropped
  progress  Int      @default(0)
  score     Int?     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Отношения
  user      User     @relation(fields: [userId], references: [id])
  anime     Anime    @relation(fields: [animeId], references: [id])

  @@unique([userId, animeId])
}